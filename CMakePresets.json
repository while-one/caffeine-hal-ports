{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "include": [
    "caffeine-build/cmake/presets/base.json",
    "cmake/presets/posix/linux.json"
  ],
  "configurePresets": [
    {
      "name": "unit-tests-gtest",
      "displayName": "Caffeine Unit Tests (Native Host)",
      "description": "Standardized unit test configuration using the host compiler",
      "inherits": "base-unit-tests-gtest",
      "cacheVariables": {
        "CFN_HAL_PORT_VENDOR": "template",
        "CFN_HAL_PORT_FAMILY": "template",
        "CFN_HAL_PORT_TARGET": "template"
      }
    },
    {
      "name": "posix-linux",
      "displayName": "POSIX Linux Implementation",
      "inherits": "base-common",
      "binaryDir": "${sourceDir}/build/posix-linux",
      "cacheVariables": {
        "CFN_HAL_PORT_VENDOR": "posix",
        "CFN_HAL_PORT_FAMILY": "linux",
        "CFN_HAL_PORT_TARGET": "linux"
      }
    },
    {
      "name": "stm32f407-release",
      "displayName": "STM32F407 (ARM Cortex-M4)",
      "inherits": "base-arm",
      "binaryDir": "${sourceDir}/build/stm32f407-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CFN_HAL_PORT_VENDOR": "stm32",
        "CFN_HAL_PORT_FAMILY": "stm32f4",
        "CFN_HAL_PORT_TARGET": "stm32f407vgtx"
      }
    },
    {
      "name": "stm32f417vg-release",
      "displayName": "STM32F417VG (ARM Cortex-M4)",
      "inherits": "base-arm",
      "binaryDir": "${sourceDir}/build/stm32f417vg-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CFN_HAL_PORT_VENDOR": "stm32",
        "CFN_HAL_PORT_FAMILY": "stm32f4",
        "CFN_HAL_PORT_TARGET": "stm32f417vgtx"
      }
    }
  ]
}